# ── App ──────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=

# ── MongoDB ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fitos

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SendGrid / SMTP) ───────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxx
EMAIL_FROM="FitOS <hello@fitos.in>"

# ── Razorpay (SaaS subscriptions — gym owner pays YOU) ──
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# ── WhatsApp (WATI) ───────────────────────────
WATI_API_URL=https://live-mt-server.wati.io/xxxxx
WATI_ACCESS_TOKEN=xxxx

# ── Cloudinary (member photos) ────────────────
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# ── SaaS Admin Panel ──────────────────────────────────────────────────────
# Set this to the MongoDB _id of YOUR gym (the platform owner's gym)
# Only users in that gym with role=owner can access /api/saas-admin/*
SAAS_ADMIN_GYM_ID=

# ── Razorpay Plan IDs (create once in your Razorpay dashboard) ────────────
RZPY_PLAN_LITE_MONTHLY=plan_xxxx
RZPY_PLAN_BASIC_MONTHLY=plan_xxxx
RZPY_PLAN_PRO_MONTHLY=plan_xxxx
RZPY_PLAN_LITE_YEARLY=plan_xxxx
RZPY_PLAN_BASIC_YEARLY=plan_xxxx
RZPY_PLAN_PRO_YEARLY=plan_xxxx
