# ── App ──────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=

# ── MongoDB ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fitos

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SendGrid / SMTP) ───────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxx
EMAIL_FROM="FitOS <hello@fitos.in>"

# ── Razorpay ───────────────────────────────────────────────
# One global, platform-level account for now — used for both:
#   1. SaaS subscriptions (gym owner pays YOU, via Razorpay Subscriptions)
#   2. Member payments (member pays their gym for membership/PT, via
#      Razorpay Orders + Checkout — card, UPI, wallets, netbanking)
# In the Razorpay Dashboard, point a webhook at
# <API_URL>/api/webhooks/razorpay with these events enabled:
#   subscription.activated, subscription.charged, subscription.halted,
#   subscription.cancelled, payment.captured
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# ── WhatsApp (WATI) ───────────────────────────
WATI_API_URL=https://live-mt-server.wati.io/xxxxx
WATI_ACCESS_TOKEN=xxxx

# ── Web Push (renewal reminders, birthday greetings, PT plan expiry alerts) ──
# Generate a keypair with: npx web-push generate-vapid-keys
# Without these set, push sends silently no-op (no error, no notification).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@fitos.in

# ── Cloudinary (member photos) ────────────────
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# ── AI chat (member portal "FitBot") ──────────
# openai | anthropic | gemini
AI_PROVIDER=gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Google Gemini (member portal AI chat + "Scan Meal" food scanner) ──────
# Free tier via Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxx
GEMINI_MODEL=gemini-3.5-flash
# Vision model used by the "Scan Meal" calorie scanner — must support image input.
# Use the full "gemini-3.5-flash" (not "-lite") for best accuracy — lite
# trades accuracy for speed. Older families (2.5-flash, 2.0-flash) have been
# progressively retired by Google — if you hit a "no longer available to new
# users" error, bump this to whatever Google's current Flash model is.
GEMINI_VISION_MODEL=gemini-3.5-flash

# ── SaaS Admin Panel ──────────────────────────────────────────────────────
# Set this to the MongoDB _id of YOUR gym (the platform owner's gym)
# Only users in that gym with role=owner can access /api/saas-admin/*
SAAS_ADMIN_GYM_ID=

# ── Razorpay Plan IDs (create once in your Razorpay dashboard) ────────────
RZPY_PLAN_LITE_MONTHLY=plan_xxxx
RZPY_PLAN_BASIC_MONTHLY=plan_xxxx
RZPY_PLAN_PRO_MONTHLY=plan_xxxx
RZPY_PLAN_LITE_YEARLY=plan_xxxx
RZPY_PLAN_BASIC_YEARLY=plan_xxxx
RZPY_PLAN_PRO_YEARLY=plan_xxxx
